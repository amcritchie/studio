<%# locals: (type:, message:) %>
<%
  styles = case type.to_s
    when "notice" then "bg-mint-900/30 border-mint-700 text-mint-300"
    when "alert"  then "bg-red-900/50 border-red-700 text-red-300"
    end
  bar_color = type.to_s == "notice" ? "bg-mint-600" : "bg-red-600"
%>
<div x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 5000)"
     x-transition:leave="transition ease-in duration-300"
     x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
     class="mb-4 p-3 border rounded-lg relative overflow-hidden <%= styles %>">
  <%= message %>
  <div class="absolute bottom-0 left-0 h-0.5 <%= bar_color %>" style="animation: progress-countdown 5s linear forwards"></div>
</div>

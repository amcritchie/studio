<%# locals: (text:, scheme: "neutral") %>
<%
  scheme_classes = case scheme.to_s
    when "success"  then "bg-mint-900/30 text-mint-300 border-mint-700/50"
    when "danger"   then "bg-red-900/50 text-red-400 border-red-700/50"
    when "warning"  then "bg-yellow-900/50 text-yellow-400 border-yellow-700/50"
    when "info"     then "bg-blue-900/30 text-blue-300 border-blue-700/50"
    when "violet"   then "bg-violet-900/30 text-violet-300 border-violet-700/50"
    when "neutral"  then "bg-gray-700/30 text-gray-400 border-gray-600/50"
    else                 "bg-navy-600 text-gray-300 border-navy-300/30"
    end
%>
<span class="badge <%= scheme_classes %>"><%= text %></span>

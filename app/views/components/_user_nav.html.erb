<%# Shared right-side navbar user section.
    Locals (all optional):
      balance_html     — raw HTML for balance display (e.g. Turf Monster wallet balance)
      extra_icons_html — raw HTML for app-specific icon buttons (e.g. refresh button)
      show_logout_link — boolean, show explicit "Log out" link (Studio uses this)
      div2_html        — raw HTML to replace default Div 2 (e.g. Turf Monster seeds bar)
%>
<% balance_html     ||= nil %>
<% extra_icons_html ||= nil %>
<% show_logout_link ||= false %>
<% div2_html        ||= nil %>

<div class="flex gap-2">
  <% if logged_in? %>
    <%# Left column: Div 1 + Div 2 stacked %>
    <div class="flex-1">
      <%# Div 1 (Bigger): balance + icons + username %>
      <div class="flex items-end gap-1 leading-none" :style="$store.devMode && 'background: cornflowerblue'">
        <% if balance_html.present? %>
          <%= raw balance_html %>
        <% end %>
        <div class="flex items-end gap-2 ml-auto">
          <%= render "components/admin_dropdown" %>
          <%= render "components/theme_toggle" %>
          <%= raw extra_icons_html %>
        </div>
        <% account_link = defined?(account_path) ? account_path : "#" %>
        <%= link_to account_link, class: "text-heading font-semibold hover:text-primary transition text-base leading-none truncate text-right", style: "max-width: 4rem" do %>
          <%= current_user.display_name %>
        <% end %>
      </div>
      <%# Div 2 (Smaller): wallet address (left) + level (right) %>
      <div style="position: relative; height: 14px; margin-top: 3px;">
        <%# Green fill bar — pure inline styles %>
        <div style="position: absolute; top: 0; left: 0; bottom: 0; width: 90%; background: #4BAF50; border-radius: 4px; z-index: 0;"></div>
        <%# Text layer 1: muted (visible outside bar) %>
        <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: space-between; padding: 0 6px; font-family: monospace; font-size: 10px; color: #6B7280; z-index: 1;">
          <span>
            <% if current_user.respond_to?(:truncated_solana) && current_user.try(:solana_connected?) %>
              <%= current_user.truncated_solana %>
            <% end %>
            <% if show_logout_link %>
              <%= link_to "Log out", logout_path, class: "text-secondary hover:text-heading text-sm font-medium transition" %>
            <% end %>
          </span>
          <% if current_user.respond_to?(:level) && current_user.level.present? %>
            <span>Level <%= current_user.level %></span>
          <% end %>
        </div>
        <%# Text layer 2: white (clip-path reveals where bar covers) %>
        <div style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: space-between; padding: 0 6px; font-family: monospace; font-size: 10px; color: white; clip-path: inset(0 10% 0 0); z-index: 2;">
          <span>
            <% if current_user.respond_to?(:truncated_solana) && current_user.try(:solana_connected?) %>
              <%= current_user.truncated_solana %>
            <% end %>
            <% if show_logout_link %>
              <%= link_to "Log out", logout_path, class: "text-secondary hover:text-heading text-sm font-medium transition" %>
            <% end %>
          </span>
          <% if current_user.respond_to?(:level) && current_user.level.present? %>
            <span>Level <%= current_user.level %></span>
          <% end %>
        </div>
      </div>
    </div>
    <%# Div 3 (Avatar): spans both rows %>
    <% account_link = defined?(account_path) ? account_path : "#" %>
    <%= link_to account_link, class: "hover:opacity-80 transition flex-shrink-0 flex items-center", "x-bind:style": "$store.devMode && 'background: lightgreen'" do %>
      <%= render "components/avatar", user: current_user, size: "nav" %>
    <% end %>
  <% else %>
    <%= render "components/admin_dropdown" %>
    <%= render "components/theme_toggle" %>
    <div class="flex items-center gap-3 ml-auto">
      <%= link_to "Log in", login_path, class: "text-heading hover:text-primary text-sm font-semibold transition" %>
      <%= link_to "Sign up", signup_path, class: "btn btn-primary btn-sm" %>
    </div>
  <% end %>
</div>

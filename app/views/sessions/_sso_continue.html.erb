<% if sso_user_available? %>
  <div class="text-center">
    <%= form_with url: sso_continue_path, method: :post, class: "inline" do %>
      <button type="submit" class="w-full px-4 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold rounded-lg transition flex items-center justify-center gap-2">
        Continue as <%= sso_display_name %>
        <span class="text-xs opacity-75">(from <%= sso_source_app %>)</span>
      </button>
    <% end %>

    <div class="flex items-center gap-3 my-4">
      <div class="flex-1 h-px bg-gray-600"></div>
      <span class="text-gray-400 text-sm">or sign in below</span>
      <div class="flex-1 h-px bg-gray-600"></div>
    </div>
  </div>
<% end %>
